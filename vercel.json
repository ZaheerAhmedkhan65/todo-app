{
  "version": 2,
  "projects": [
    {
      "path": "backend",
      "settings": {
        "framework": null,
        "buildCommand": null,
        "outputDirectory": "public",
        "installCommand": "cd backend && npm install"
      }
    }
  ],
  "functions": {
    "backend/api/index.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend/api/index.js"
    }
  ]
}